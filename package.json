{
  "name": "container-base",
  "version": "0.0.0",
  "private": true,
  "description": "Tooling-only manifest: prettier formatting for this repo's Markdown, JSON and YAML, and the devcontainer CLI that builds the images. No runtime JavaScript.",
  "config": {
    "devImage": "container-base:dev-test"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "build:dev": "devcontainer build --workspace-folder . --config images/dev/devcontainer.json --frozen-lockfile --image-name $npm_package_config_devImage",
    "test:dev": "IMAGE=$npm_package_config_devImage bats test/dev"
  },
  "devDependencies": {
    "@devcontainers/cli": "^0.88.0",
    "bats": "^1.13.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "prettier": "^3.9.6"
  },
  "lint-staged": {
    "*.{md,json,jsonc,yaml,yml,html}": "prettier --check"
  }
}
